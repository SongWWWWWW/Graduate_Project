# ============================================================
# novel 项目环境变量配置模板
# 复制此文件为 .env，填入你自己的配置值
# 启动项目时通过 JVM 参数注入：-Dspring.profiles.active=dev
# ============================================================

# AI 大模型配置（SiliconFlow / DeepSeek / 阿里百炼）
SILICONFLOW_API_KEY=sk-你的API密钥
SILICONFLOW_BASE_URL=https://api.siliconflow.cn
AI_CHAT_MODEL=deepseek-ai/DeepSeek-V3

# 数据库配置
MYSQL_URL=jdbc:mysql://localhost:3306/novel?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=你的MySQL密码

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=你的Redis密码（如无密码留空）

# Elasticsearch 配置（可选，AI语义搜索需要）
ES_ENABLED=false
ES_URI=http://localhost:9200
ES_USERNAME=
ES_PASSWORD=

# RabbitMQ 配置（可选，AI向量数据同步需要）
RABBITMQ_ADDR=amqp://guest:guest@localhost:5672
RABBITMQ_VHOST=novel

# JWT 密钥（生产环境务必更换为强随机字符串）
JWT_SECRET=E66559580A1ADF48CDD928516062F12E

# 文件上传路径（Windows 示例）
UPLOAD_PATH=C:/Users/你的用户名/upload
