# AI 大模型配置（SiliconFlow）
# 去 https://cloud.siliconflow.cn 注册获取 API Key
SILICONFLOW_API_KEY=sk-uvdesqlkqplxstmlpjrwjcyvdburhxgnvpbhgrxglbkiyfbv
SILICONFLOW_BASE_URL=https://api.siliconflow.cn
AI_CHAT_MODEL=deepseek-ai/DeepSeek-V3

# 数据库配置
MYSQL_URL=jdbc:mysql://localhost:3306/novel?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=191239

# Redis 配置（本地已运行，默认无密码）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Elasticsearch 配置（可选，AI语义搜索需要）
